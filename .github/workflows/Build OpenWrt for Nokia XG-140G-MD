name: Build OpenWrt for Nokia XG-140G-MD

on:
  workflow_dispatch:          # 手动触发
  push:
    branches:
      - main                  # 推送至 main 分支自动触发

jobs:
  build:
    runs-on: ubuntu-22.04
    env:
      OPENWRT_VERSION: "openwrt-23.05"          # 源码分支，与软件源版本一致
      FEEDS_CONF: "feeds.conf.default"          # feeds 配置文件
      CONFIG_FILE: ".config"                    # 编译配置文件

    steps:
      - name: Checkout OpenWrt source
        uses: actions/checkout@v4
        with:
          repository: openwrt/openwrt
          ref: ${{ env.OPENWRT_VERSION }}
          path: openwrt

      - name: Checkout custom files
        uses: actions/checkout@v4
        with:
          path: openwrt/custom    # 将仓库中的 files 等自定义内容放入临时目录

      - name: Merge custom files into source
        run: |
          # 将 custom 目录下的所有文件覆盖到源码根目录
          cp -r custom/files openwrt/ 2>/dev/null || true
          cp custom/.config openwrt/ 2>/dev/null || true
          cp custom/feeds.conf.default openwrt/ 2>/dev/null || true

      - name: Setup ccache
        uses: actions/cache@v4
        with:
          path: ~/.ccache
          key: ${{ runner.os }}-ccache-${{ env.OPENWRT_VERSION }}-${{ github.run_id }}
          restore-keys: |
            ${{ runner.os }}-ccache-${{ env.OPENWRT_VERSION }}-

      - name: Setup source download cache
        uses: actions/cache@v4
        with:
          path: openwrt/dl
          key: ${{ runner.os }}-dl-${{ env.OPENWRT_VERSION }}-${{ hashFiles('openwrt/.config') }}
          restore-keys: |
            ${{ runner.os }}-dl-${{ env.OPENWRT_VERSION }}-

      - name: Install dependencies
        run: |
          sudo apt update
          sudo apt install -y build-essential clang flex bison g++ gawk \
            gcc-multilib g++-multilib gettext git libncurses-dev libssl-dev \
            python3-distutils rsync unzip zlib1g-dev file wget ccache

      - name: Update feeds
        working-directory: openwrt
        run: |
          ./scripts/feeds update -a
          ./scripts/feeds install -a

      - name: Validate and expand .config
        working-directory: openwrt
        run: make defconfig

      - name: Show target configuration summary
        working-directory: openwrt
        run: |
          echo "===== Target Configuration ====="
          grep -E "^CONFIG_TARGET_(airoha|BOARD|DEVICE)" .config || true

      - name: Download all sources
        working-directory: openwrt
        run: make download -j$(nproc)

      - name: Compile firmware
        working-directory: openwrt
        env:
          CCACHE_DIR: ~/.ccache
        run: |
          export PATH="/usr/lib/ccache:$PATH"
          make -j$(nproc) V=s

      - name: Prepare build logs for upload
        if: always()
        working-directory: openwrt
        run: |
          mkdir -p logs
          # 收集编译日志（无截断）
          if [ -f logs/compile.log ]; then
            cp logs/compile.log logs/compile_full.log 2>/dev/null || true
          fi
          # 收集内核和软件包构建日志
          find build_dir/target-aarch64_cortex-a53_musl -name "*.log" -exec cp {} logs/ \; 2>/dev/null || true
          # 输出 .config 和版本信息
          cp .config logs/config.txt
          echo "OpenWrt version: ${{ env.OPENWRT_VERSION }}" > logs/version.txt
          echo "Build date: $(date)" >> logs/version.txt

      - name: Upload firmware artifacts
        uses: actions/upload-artifact@v4
        with:
          name: openwrt-nokia-xg140gmd-firmware
          path: |
            openwrt/bin/targets/airoha/an7581/*.bin
            openwrt/bin/targets/airoha/an7581/*.img
            openwrt/bin/targets/airoha/an7581/sha256sums

      - name: Upload build logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: build-logs
          path: openwrt/logs/
