# ===================== 设备目标 =====================
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_airoha_an7581_DEVICE_nokia_xg-040g-md=y
CONFIG_TARGET_ROOTFS_PARTSIZE=512

# ===================== 基础系统 =====================
CONFIG_BUSYBOX_CONFIG_FEATURE_TOP_SMP_CPU=y
CONFIG_BUSYBOX_CONFIG_PASSWD=y
CONFIG_TARGET_INIT_PATH="/usr/sbin:/usr/bin:/sbin:/bin"
CONFIG_TARGET_PREINIT_SUPPRESS_FAILSAFE_NETWORK=y

# ===================== 优化配置 =====================
CONFIG_TARGET_OPTIMIZATION="-Os -pipe -march=armv8-a+crc+crypto -mcpu=cortex-a53"
CONFIG_USE_MUSL=y
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256

# ===================== LuCI 中文界面 =====================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci_base=y
CONFIG_LUCI_LANG_zh_Hans=y

# ===================== 软件包管理界面 =====================
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_luci_app_opkg=y

# ===================== 启用必要的 rpcd 模块 =====================
CONFIG_PACKAGE_rpcd_mod_luci=y
CONFIG_PACKAGE_rpcd_mod_rrdns=y

# ===================== 看门狗支持 =====================
CONFIG_PACKAGE_kmod_wdt_en7581=y
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_CORE=y
CONFIG_WATCHDOG_HANDLE_BOOT_ENABLED=y

# ===================== AN7581 核心驱动 =====================
CONFIG_PACKAGE_kmod_airoha_eth=y
CONFIG_PACKAGE_kmod_phy_en8811h=y
CONFIG_PACKAGE_airoha_en8811h_firmware=y
CONFIG_PACKAGE_kmod_airoha_npu=y
CONFIG_PACKAGE_airoha_npu_firmware=y
CONFIG_PACKAGE_kmod_mtd_spi_nand=y
CONFIG_PACKAGE_kmod_spi_airoha_snfi=y
CONFIG_PACKAGE_kmod_spi_nor=y
CONFIG_PACKAGE_kmod_hwmon_airoha=y
CONFIG_PACKAGE_kmod_thermal_airoha=y
CONFIG_PACKAGE_kmod_reset_airoha=y
CONFIG_PACKAGE_kmod_gpio_button_hotplug=y
CONFIG_PACKAGE_kmod_leds_airoha=y
CONFIG_PACKAGE_kmod_cpufreq_en7581=y
CONFIG_PACKAGE_kmod_pcie_airoha=y

# ===================== USB 支持 =====================
CONFIG_PACKAGE_kmod_usb2=y
CONFIG_PACKAGE_kmod_usb3=y
CONFIG_PACKAGE_kmod_usb_storage=y
CONFIG_PACKAGE_kmod_usb_ehci=y
CONFIG_PACKAGE_kmod_phy_airoha_usb=y

# ===================== Flash 与 MTD =====================
CONFIG_KERNEL_MTD=y
CONFIG_KERNEL_MTD_PARTS=y
CONFIG_KERNEL_MTD_BLOCK=y
CONFIG_KERNEL_MTD_CHAR=y
CONFIG_KERNEL_MTD_SPI_NOR=y
CONFIG_KERNEL_SPI_MASTER=y

# ===================== 网络基础 =====================
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_dnsmasq_full=y
CONFIG_PACKAGE_odhcpd=y
CONFIG_PACKAGE_odhcp6c=y

# ===================== PPPoE 拨号支持 =====================
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp_mod_pppoe=y
CONFIG_PACKAGE_kmod_ppp=y
CONFIG_PACKAGE_kmod_pppoe=y
CONFIG_PACKAGE_kmod_pppox=y

# ===================== 网络加速 =====================
CONFIG_PACKAGE_kmod_ipt_fullconenat=y
CONFIG_PACKAGE_kmod_ipt_offload=y
CONFIG_PACKAGE_kmod_nf_flow=y
CONFIG_PACKAGE_kmod_nft_offload=y
CONFIG_PACKAGE_ethtool=y
CONFIG_KERNEL_NFT_FLOW_OFFLOAD=y

# ===================== TCP 优化 =====================
CONFIG_KERNEL_TCP_CONG_BBR=y
CONFIG_KERNEL_DEFAULT_TCP_CONG="bbr"

# ===================== 科学上网内核依赖 =====================
CONFIG_PACKAGE_kmod_tun=y
CONFIG_PACKAGE_kmod_nft_tproxy=y

# ===================== VLAN / 桥接支持 =====================
CONFIG_PACKAGE_kmod_8021q=y
CONFIG_PACKAGE_kmod_bridge=y
CONFIG_PACKAGE_kmod_br_netfilter=y

# ===================== 内核网络选项 =====================
CONFIG_KERNEL_NET_VENDOR_MEDIATEK=n
CONFIG_KERNEL_NET_VENDOR_REALTEK=n
CONFIG_KERNEL_NET_VENDOR_SYNOPSYS=n
CONFIG_KERNEL_NET_SWITCHDEV=y
CONFIG_KERNEL_IPV6=y
CONFIG_KERNEL_BRIDGE_VLAN_FILTERING=y

# ===================== SSH 配置 =====================
CONFIG_PACKAGE_dropbear=y
CONFIG_DROPBEAR_CURVE25519=y
